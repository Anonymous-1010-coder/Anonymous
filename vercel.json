{
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/next"
    },
    {
      "src": "backend/src/index.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/_/backend/(.*)", "dest": "backend/src/index.ts/$1" },
    { "src": "/(.*)", "dest": "frontend/$1" }
  ]
}
